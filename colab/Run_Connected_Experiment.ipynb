e and ready!\n"]}],"source":["# 3. Boot Server normally (it will use the fast internal disk, NOT Drive)\n","!nohup ollama serve \u003e ollama.log 2\u003e\u00261 \u0026\n","time.sleep(5)\n","print(\"✅ Ollama Server Awake and ready!\")"]},{"cell_type":"code","execution_count":9,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":92,"status":"ok","timestamp":1777443258597,"user":{"displayName":"L.A.K.S. ATHUKORALA","userId":"13293977363303398555"},"user_tz":-330},"id":"LQCdoj_hZ4_1","outputId":"9abf06a5-f6b2-4add-de6c-3e16fc4c70e3"},"outputs":[{"name":"stdout","output_type":"stream","text":["Ollama is running"]}],"source":["# 6. Test if it is running\n","!curl http://localhost:11434"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"Gy6UkIU9Z7Ps"},"outputs":[],"source":["# 7. Pull the model!\n","!ollama pull gemma3:4b"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"88PWuVYSgXLD"},"outputs":[],"source":["!ollama rm gemma3:270m"]},{"cell_type":"code","execution_count":10,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":128,"status":"ok","timestamp":1777443260719,"user":{"displayName":"L.A.K.S. ATHUKORALA","userId":"13293977363303398555"},"user_tz":-330},"id":"pU_dI5XaaYkO","outputId":"2d9e39c1-b1b1-4ef9-af61-364206c3a419"},"outputs":[{"name":"stdout","output_type":"stream","text":["NAME         ID              SIZE      MODIFIED       \n","gemma3:4b    a2af6cc3eb7f    3.3 GB    18 seconds ago    \n"]}],"source":["!ollama list"]},{"cell_type":"code","execution_count":11,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":44630,"status":"ok","timestamp":1777443307254,"user":{"displayName":"L.A.K.S. ATHUKORALA","userId":"13293977363303398555"},"user_tz":-330},"id":"C8B8eqfOamW_","outputId":"653680f2-a773-4ccc-8cf0-7d9b9be74d2d"},"outputs":[{"name":"stdout","output_type":"stream","text":["RGB stands for Red, Green, and Blue. It’s a color model used in displays and digital images by combining these three colors to create a wide range of colors. \n","\n","Essentially, it’s how computers represent color! 🎨💻\n","\n"]}],"source":["\"\"\"### Testing on Text Input\"\"\"\n","\n","import ollama\n","response = ollama.chat(model='gemma3:4b', messages=[\n","  {'role': 'user', 'content': 'what is rgb, answer short'},\n","])\n","print(response['message']['content'])"]},{"cell_type":"markdown","metadata":{"id":"intro"},"source":["# SmartHVAC Studio: Backend Worker (Layer 3)\n","This executable notebook acts as the **Coordination Engine**. It polls Firebase for new jobs, runs AI generation (Layer 4), executes EnergyPlus simulations (Layer 5), and uploads results.\n","\n","---"]},{"cell_type":"markdown","metadata":{"id":"VWKVNrz6_fxb"},"source":["## 1. Mount drive"]},{"cell_type":"code","execution_count":12,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"executionInfo":{"elapsed":10083,"status":"ok","timestamp":1777443322971,"user":{"displayName":"L.A.K.S. ATHUKORALA","userId":"13293977363303398555"},"user_tz":-330},"id":"q5FuC37ePe5L","outputId":"62be58c4-9b76-40de-be60-5da458019cfb"},"outputs":[{"name":"stdout","output_type":"stream","text":["Fixed Base.idf successfully!\n","✅ Server Cache Cleared, Cleaned Drive, and Hard-Patched the IDF File! You are ready to simulate.\n"]}],"source":["import os, sys, importlib\n","\n","# 1. Forcefully remove old ghost folders so your Drive is clean\n","if os.path.exists('../sim_runs'):\n","    !rm -rf ../sim_runs/\n","if os.path.exists('sim_runs'):\n","    !rm -rf sim_runs/\n","if os.path.exists('RunFiles'):\n","    !rm -rf RunFiles/\n","\n","# 2. Forcefully fix Base.idf directly on the server to strip the Duplicate Zone\n","base_path = 'templates/Base.idf'\n","if os.path.exists(base_path):\n","    with open(base_path, 'r') as f:\n","        lines = f.readlines()\n","\n","    # Strip everything from the first \"Zone,\" onwards to remove duplicated geometry\n","    with open(base_path, 'w') as f:\n","        for i, line in enumerate(lines):\n","            # If we hit the word \"Zone,\" we stop writing the rest of the template\n","            if \"Zone,\" in line.strip() and \"Zone ONE\" not in line and \"Zone,\" == line.strip():\n","                pass # Just a safety\n","            if line.strip() == \"Zone,\":\n","                break\n","            f.write(line)\n","    print(\"Fixed Base.idf successfully!\")\n","else:\n","    print(f\"Could not find {base_path} - ensure you are in the correct directory.\")\n","\n","# 3. Force Python to reload the fixed python files from disk\n","sys.path.append(os.getcwd())\n","import backend.geometry_util as geometry_util\n","import simulation_runner\n","importlib.reload(geometry_util)\n","importlib.reload(simulation_runner)\n","\n","print(\"✅ Server Cache Cleared, Cleaned Drive, and Hard-Patched the IDF File! You are ready to simulate.\")\n"]},{"cell_type":"code","execution_count":null,"metadata":{"collapsed":true,"id":"ORF5K-Bd-edF"},"outputs":[],"source":["!python verify_phase2.py"]},{"cell_type":"markdown","metadata":{"id":"setup_title"},"source":["## 2. Setup Environment"]},{"cell_type":"code","execution_count":13,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"collapsed":true,"executionInfo":{"elapsed":30007,"status":"ok","timestamp":1777443365091,"user":{"displayName":"L.A.K.S. ATHUKORALA","userId":"13293977363303398555"},"user_tz":-330},"id":"install_deps","outputId":"7540adfe-b630-42ed-9c7c-9263cb007cb5"},"outputs":[{"name":"stdout","output_type":"stream","text":["Collecting firebase-admin==6.2.0 (from -r requirements.txt (line 1))\n","  Downloading firebase_admin-6.2.0-py3-none-any.whl.metadata (1.4 kB)\n","Requirement already satisfied: pandas in /usr/local/lib/python3.12/dist-packages (from -r requirements.txt (line 3)) (2.2.2)\n","Requirement already satisfied: matplotlib in /usr/local/lib/python3.12/dist-packages (from -r requirements.txt (line 4))